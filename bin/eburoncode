#!/usr/bin/env bash
# ─── eburoncode — Multi-Agent AI Conductor ────────────────────────────
# Detects all installed AI agents and routes tasks to the best one.
# Each agent gets skills loaded as playbooks for its domain.
#
# Usage:
#   eburoncode                         → OpenCode TUI (default, coding)
#   eburoncode "build a dashboard"     → OpenCode with prompt
#   eburoncode --hermes "research X"   → Hermes Agent (memory, autonomous)
#   eburoncode --claude "review this"  → Claude Code (review, security)
#   eburoncode --codex "audit code"    → Codex CLI (second opinion)
#   eburoncode --list                  → Show all detected agents
#   eburoncode --agent hermes "task"   → Generic agent routing
#
# Skill Routing (loaded into each agent):
#   $skill-name  → explicit invocation
#   trigger words → implicit matching via AGENTS.md
# ───────────────────────────────────────────────────────────────────────

set -euo pipefail

EBURON_MODEL="${EBURON_MODEL:-media-pipe/eburon-sandbox-worker}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"
AG_SKILLS="${HOME}/.agents/skills"
OP_SKILLS="${HOME}/.opencode/skills"

# ── Colors ──
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
RED='\033[0;31m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
MAGENTA='\033[0;35m'; BLUE='\033[0;34m'

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  ╔═══════════════════════════════════════════╗"
    echo "  ║  🤖 eburoncode — Multi-Agent Conductor   ║"
    echo "  ║  Eburon AI · ollama://$EBURON_MODEL"
    echo "  ╚═══════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ── Ensure infrastructure ──
ensure_ollama() {
    curl -s --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1 && return 0
    echo -e "${YELLOW}Starting Ollama...${NC}"
    command -v ollama >/dev/null 2>&1 || { echo -e "${RED}✗ Ollama not installed${NC}"; exit 1; }
    ollama serve >/dev/null 2>&1 & sleep 2
    curl -s --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1 && echo -e "${GREEN}✓ Ollama${NC}" || { echo -e "${RED}✗ Cannot reach Ollama${NC}"; exit 1; }
}

ensure_model() {
    ollama list 2>/dev/null | grep -q "$EBURON_MODEL" && return 0
    echo -e "${YELLOW}Pulling $EBURON_MODEL (1GB)...${NC}"
    ollama pull "$EBURON_MODEL" || { echo -e "${RED}✗ Pull failed${NC}"; exit 1; }
}

ensure_config() {
    local cf="$HOME/.config/opencode/opencode.json"
    mkdir -p "$(dirname "$cf")"
    
    # Ruthless self-healing: if config is broken or contains 'fallback', reset it.
    # This is the only way to stop the 'Aborted (core dumped)' crash in opencode.
    if [ -f "$cf" ]; then
        if grep -q "fallback" "$cf"; then
            echo -e "${YELLOW}Critical: Invalid config detected. Resetting opencode.json...${NC}"
            rm -f "$cf"
        fi
    fi

    if [ ! -f "$cf" ]; then
        cat > "$cf" <<CFG
{
  "\$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "model": "ollama/$EBURON_MODEL",
  "skills": { "paths": ["~/.opencode/skills", "~/.agents/skills"] },
  "provider": {
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": { "baseURL": "http://127.0.0.1:11434/v1" }
    }
  },
  "disabled_providers": []
}
CFG
    fi
}

# ── Agent Detection ────────────────────────────────────────────────────

# Agent registry functions
agent_bin() {
    case "$1" in
        opencode) echo "opencode" ;; hermes) echo "hermes" ;; claude) echo "claude" ;;
        codex) echo "codex" ;; gemini) echo "gemini" ;; *) echo "" ;; esac
}
agent_desc() {
    case "$1" in
        opencode) echo "OpenCode TUI — coding, building, editing" ;;
        hermes)   echo "Hermes Agent — personal AI, memory, autonomous, research" ;;
        claude)   echo "Claude Code — review, security, architecture, planning" ;;
        codex)    echo "Codex CLI — second opinion, adversarial review, audit" ;;
        gemini)   echo "Gemini CLI — big context, plan review, analysis" ;;
        *) echo "" ;; esac
}
agent_domain() {
    case "$1" in
        opencode) echo "coding:building:editing:full-stack" ;;
        hermes)   echo "research:memory:autonomous:scheduling:personal" ;;
        claude)   echo "review:security:architecture:planning:docs" ;;
        codex)    echo "review:audit:challenge:second-opinion" ;;
        gemini)   echo "analysis:plan-review:big-context:research" ;;
        *) echo "" ;; esac
}

detect_agents() {
    :  # registry is in functions above
}

# ── Detect installed agents ──
scan_agents() {
    local count=0
    for name in opencode hermes claude codex gemini; do
        local bin=$(agent_bin "$name")
        [ -n "$bin" ] && command -v "$bin" >/dev/null 2>&1 && count=$((count + 1))
    done
    echo "$count"
}

# ── Show agent status ──
show_agents() {
    echo ""
    echo -e "  ${CYAN}Available Agents:${NC}"
    echo ""
    for name in opencode hermes claude codex gemini; do
        local bin=$(agent_bin "$name")
        if [ -n "$bin" ] && command -v "$bin" >/dev/null 2>&1; then
            local ver=$($bin --version 2>/dev/null | head -1 | cut -c1-40 || echo "installed")
            echo -e "  ${GREEN}●${NC} ${BOLD}$name${NC} ${DIM}— $(agent_desc "$name")${NC}"
            echo -e "    ${DIM}domains: $(agent_domain "$name")${NC}"
        else
            echo -e "  ${RED}○${NC} ${DIM}$name — not installed${NC}"
        fi
    done
    echo ""
}

# ── Match task to best agent ──
match_agent() {
    local task="${1:-}"
    local best="opencode"  # default

    # Keyword routing
    case "$(echo "$task" | tr '[:upper:]' '[:lower:]')" in
        *research*|*investigate*|*memory*|*remember*|*autonomous*|*cron*|*schedule*|*personal*)
            command -v hermes >/dev/null 2>&1 && best="hermes" ;;
        *review*|*audit*|*security*|*vulnerability*|*architecture*|*plan*|*document*)
            command -v claude >/dev/null 2>&1 && best="claude" ;;
        *second*opinion*|*challenge*|*adversarial*|*codex*)
            command -v codex >/dev/null 2>&1 && best="codex" ;;
        *analyze*|*analysis*|*big*context*|*compare*)
            command -v gemini >/dev/null 2>&1 && best="gemini";;
    esac

    echo "$best"
}

# ── Launch an agent with skills ──
launch_agent() {
    local agent="$1"
    shift
    local bin=$(agent_bin "$agent")
    local args=("$@")

    echo -e "${CYAN}Launching:${NC} ${BOLD}$agent${NC} ${DIM}($(agent_desc "$agent"))${NC}"
    echo -e "${CYAN}Domains:${NC}  $(agent_domain "$agent")"
    echo ""

    if [ ! -f "AGENTS.md" ] && [ -f "$HOME/.agents/AGENTS.md" ]; then
        cp "$HOME/.agents/AGENTS.md" ./AGENTS.md 2>/dev/null || true
    fi

    # Launch using ollama launch for robust model injection
    exec ollama launch opencode --model "$EBURON_MODEL" "${args[@]}"
}

# ── Show status ──
show_status() {
    local agent_count=$(ls -d "$AG_SKILLS"/*/ 2>/dev/null | wc -l | tr -d ' ')
    local op_count=$(ls -d "$OP_SKILLS"/*/ 2>/dev/null | wc -l | tr -d ' ')
    local agents=$(scan_agents)
    echo ""
    echo -e "  ${CYAN}Infrastructure:${NC}"
    echo -e "    Ollama:  $(ollama_running && echo -e "${GREEN}running${NC}" || echo -e "${RED}stopped${NC}")"
    echo -e "    Model:   ${BOLD}$EBURON_MODEL${NC}"
    echo -e "    Skills:  ${BOLD}$((agent_count + op_count))${NC} ($agent_count agent + $op_count opencode)"
    echo -e "    Agents:  ${BOLD}$agents${NC} available"
    echo ""
}

# ── Help ──
show_help() {
    banner
    echo -e "${BOLD}Usage:${NC}"
    echo "  eburoncode                     OpenCode TUI (default)"
    echo "  eburoncode \"build a todo app\"  OpenCode with prompt"
    echo "  eburoncode /path/to/project    Launch in specific project"
    echo ""
    echo -e "${BOLD}Agent Routing:${NC}"
    echo "  eburoncode --hermes \"task\"     Hermes Agent (research, memory, autonomous)"
    echo "  eburoncode --claude \"task\"     Claude Code (review, security, architecture)"
    echo "  eburoncode --codex \"task\"      Codex CLI (second opinion, audit)"
    echo "  eburoncode --gemini \"task\"     Gemini CLI (big context analysis)"
    echo "  eburoncode --agent NAME \"task\" Route to specific agent by name"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo "  eburoncode --list              List all detected agents"
    echo "  eburoncode --status            Show infrastructure status"
    echo "  eburoncode --help              This help"
    echo ""
    echo -e "${BOLD}Skill Routing (in every agent):${NC}"
    echo '  $skill-name                    Explicit invocation'
    echo '  "build a dashboard"            Implicit matching via trigger words'
    echo '  skill-orchestrator             Bootstrap meta-skill'
}

# ── Main ────────────────────────────────────────────────────────────────
main() {
    banner
    detect_agents
    local target_agent=""
    local task_args=()

    # Parse flags
    while [ $# -gt 0 ]; do
        case "$1" in
            --hermes)   target_agent="hermes"; shift ;;
            --claude)   target_agent="claude"; shift ;;
            --codex)    target_agent="codex"; shift ;;
            --gemini)   target_agent="gemini"; shift ;;
            --agent)    target_agent="${2:-opencode}"; shift 2 ;;
            --list)     show_agents; exit 0 ;;
            --status)   ensure_ollama; ensure_model; show_status; show_agents; exit 0 ;;
            --help)     show_help; exit 0 ;;
            --*)        echo -e "${RED}Unknown: $1${NC}"; show_help; exit 1 ;;
            -*)         task_args+=("$1"); shift ;;
            *)          task_args+=("$1"); shift ;;
        esac
    done

    # Default agent
    [ -z "$target_agent" ] && target_agent="opencode"

    # Verify agent is installed
    local bin=$(agent_bin "$target_agent")
    if [ -z "$bin" ] || ! command -v "$bin" >/dev/null 2>&1; then
        echo -e "${RED}✗ $target_agent not installed${NC}"
        echo ""
        echo "Install options:"
        echo "  Hermes:  curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash"
        echo "  Claude:  npm install -g @anthropic-ai/claude-code"
        echo "  Codex:   npm install -g @openai/codex"
        echo "  Gemini:  npm install -g @anthropic-ai/gemini-cli"
        echo "  OpenCode: curl -fsSL https://opencode.ai/install | bash"
        exit 1
    fi

    # Ensure infra for all agents
    ensure_ollama
    ensure_model
    ensure_config

    # Show what we're doing
    show_status

    # Route: if first arg is a directory, cd into it
    if [ "${#task_args[@]}" -gt 0 ] && [ -d "${task_args[0]}" ]; then
        cd "${task_args[0]}"
        task_args=("${task_args[@]:1}")
    fi

    launch_agent "$target_agent" "${task_args[@]}"
}

main "$@"
