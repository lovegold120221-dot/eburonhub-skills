#!/usr/bin/env bash
# ─── eburoncode ───────────────────────────────────────────────────────
# Launch OpenCode TUI powered by the Eburon AI sandbox model.
# Auto-bootstraps the full skill activation environment:
#   Ollama → Model → Skills Index → AGENTS.md → OpenCode
#
# Usage:
#   eburoncode                       # Launch in current directory
#   eburoncode /path/to/project      # Launch in specific project
#   eburoncode "build me a todo app" # Launch with initial prompt
#
# Skill Activation:
#   $skill-name          Explicit invocation (loads full SKILL.md)
#   "build a UI"         Implicit matching via description trigger words
#   skill-orchestrator   Bootstrap meta-skill for complex workflows
# ───────────────────────────────────────────────────────────────────────

set -euo pipefail

EBURON_MODEL="${EBURON_MODEL:-media-pipe/eburon-sandbox-worker}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"
OPENCODE_BIN="${OPENCODE_BIN:-opencode}"
SKILL_INDEX="${HOME}/.config/opencode/skills-index.md"
AGENTS_TEMPLATE="${HOME}/.agents/AGENTS.md"
OP_SKILLS="${HOME}/.opencode/skills"
AG_SKILLS="${HOME}/.agents/skills"

# ── Colors ──
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
RED='\033[0;31m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  ╔═══════════════════════════════════════════╗"
    echo "  ║     🤖 eburoncode — Eburon AI + OpenCode ║"
    echo "  ║     model: $EBURON_MODEL"
    echo "  ╚═══════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ── Ensure Ollama running ──
ensure_ollama() {
    curl -s --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1 && return 0
    echo -e "${YELLOW}Ollama not running — starting...${NC}"
    command -v ollama >/dev/null 2>&1 || { echo -e "${RED}✗ Ollama not installed${NC}"; exit 1; }
    ollama serve >/dev/null 2>&1 & sleep 2
    curl -s --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1 && echo -e "${GREEN}✓ Ollama started${NC}" || { echo -e "${RED}✗ Cannot reach Ollama${NC}"; exit 1; }
}

# ── Ensure model pulled ──
ensure_model() {
    ollama list 2>/dev/null | grep -q "$EBURON_MODEL" && return 0
    echo -e "${YELLOW}Pulling $EBURON_MODEL (1GB)...${NC}"
    ollama pull "$EBURON_MODEL" || { echo -e "${RED}✗ Pull failed${NC}"; exit 1; }
    echo -e "${GREEN}✓ Model ready${NC}"
}

# ── Build skill index (progressive disclosure) ──
build_skill_index() {
    local total=0
    local timestamp=$(date '+%H:%M:%S')
    
    {
        echo "# Skill Routing Index"
        echo "> ${timestamp} · Scan name+description only — load full SKILL.md on match"
        echo ""
        echo "| Trigger Words | Skill |"
        echo "|--------------|-------|"
    } > "$SKILL_INDEX"

    for dir in "$AG_SKILLS" "$OP_SKILLS"; do
        [ -d "$dir" ] || continue
        for skill_dir in "$dir"/*/; do
            [ -d "$skill_dir" ] || continue
            local f="$skill_dir/SKILL.md"
            [ -f "$f" ] || continue
            local name=$(grep "^name:" "$f" | head -1 | sed 's/name: *//')
            local hint=$(grep "^argument-hint:" "$f" | head -1 | sed 's/argument-hint: *//')
            [ -z "$name" ] && continue
            echo "| \`${hint:-$name}\` | \`${name}\` |" >> "$SKILL_INDEX"
            total=$((total + 1))
        done
    done
    
    echo "" >> "$SKILL_INDEX"
    echo "**$total skills** · Use \`\$skill-name\` to invoke · Match trigger words for implicit loading" >> "$SKILL_INDEX"
}

# ── Bootstrap project for skills ──
bootstrap_project() {
    local project_dir="${1:-$(pwd)}"
    
    # Install/update AGENTS.md
    if [ -f "$AGENTS_TEMPLATE" ]; then
        if [ ! -f "$project_dir/AGENTS.md" ]; then
            cp "$AGENTS_TEMPLATE" "$project_dir/AGENTS.md"
            echo -e "${GREEN}✓ Created AGENTS.md with skill routing rules${NC}"
        elif ! grep -q "Progressive Disclosure Rule" "$project_dir/AGENTS.md" 2>/dev/null; then
            # Existing AGENTS.md but doesn't have skill routing — append it
            echo "" >> "$project_dir/AGENTS.md"
            cat "$AGENTS_TEMPLATE" >> "$project_dir/AGENTS.md"
            echo -e "${GREEN}✓ Patched AGENTS.md with skill routing rules${NC}"
        else
            echo -e "${DIM}  AGENTS.md OK${NC}"
        fi
    fi

    # Ensure .agents/skills directory exists in project
    mkdir -p "$project_dir/.agents/skills"
    
    # Symlink user skills into project if not already present
    if [ ! -d "$project_dir/.agents/skills/skill-orchestrator" ] && [ -d "$AG_SKILLS" ]; then
        for skill_dir in "$AG_SKILLS"/*/; do
            local name=$(basename "$skill_dir")
            [ -e "$project_dir/.agents/skills/$name" ] || ln -sf "$skill_dir" "$project_dir/.agents/skills/$name" 2>/dev/null
        done
    fi
}

# ── Ensure OpenCode config is fully wired for skills ──
ensure_config() {
    local config_file="$HOME/.config/opencode/opencode.json"
    mkdir -p "$(dirname "$config_file")"

    # Create from scratch if missing
    if [ ! -f "$config_file" ]; then
        cat > "$config_file" <<EOF
{
  "provider": "ollama",
  "model": "$EBURON_MODEL",
  "instructions": ["AGENTS.md", "~/.config/opencode/developer.md"],
  "skills": { "paths": ["~/.opencode/skills", "~/.agents/skills"] },
  "ollama": { "url": "$OLLAMA_URL" }
}
EOF
        echo -e "${GREEN}✓ OpenCode config created${NC}"
        return
    fi

    # Config exists — patch missing keys using python3
    if ! command -v python3 >/dev/null 2>&1; then
        echo -e "${DIM}  Config exists (no python3 to patch)${NC}"
        return
    fi

    local status
    status=$(python3 -c "
import json
with open('$config_file') as f:
    cfg = json.load(f)
changed = False
if 'instructions' not in cfg:
    cfg['instructions'] = ['AGENTS.md', '~/.config/opencode/developer.md']
    changed = True
elif 'AGENTS.md' not in cfg.get('instructions', []):
    cfg['instructions'] = ['AGENTS.md'] + [i for i in cfg.get('instructions', []) if i != 'AGENTS.md']
    if '~/.config/opencode/developer.md' not in cfg['instructions']:
        cfg['instructions'].append('~/.config/opencode/developer.md')
    changed = True
if 'skills' not in cfg:
    cfg['skills'] = {'paths': ['~/.opencode/skills', '~/.agents/skills']}
    changed = True
else:
    paths = cfg['skills'].get('paths', [])
    for p in ['~/.opencode/skills', '~/.agents/skills']:
        if p not in paths:
            paths.append(p)
            changed = True
    cfg['skills']['paths'] = paths
if changed:
    with open('$config_file', 'w') as f:
        json.dump(cfg, f, indent=2)
    print('patched')
else:
    print('ok')
" 2>/dev/null)

    case "$status" in
        patched) echo -e "${GREEN}✓ OpenCode config patched — AGENTS.md + skills paths${NC}" ;;
        ok)      echo -e "${DIM}  OpenCode config OK${NC}" ;;
        *)       echo -e "${DIM}  OpenCode config checked${NC}" ;;
    esac
}

# ── Show status ──
show_status() {
    local agent_count=$(ls -d "$AG_SKILLS"/*/ 2>/dev/null | wc -l | tr -d ' ')
    local op_count=$(ls -d "$OP_SKILLS"/*/ 2>/dev/null | wc -l | tr -d ' ')
    local total=$((agent_count + op_count))
    
    echo ""
    echo -e "  ${CYAN}Model:${NC}    $EBURON_MODEL"
    echo -e "  ${CYAN}Provider:${NC}  ollama → $OLLAMA_URL"
    echo -e "  ${CYAN}Skills:${NC}   ${BOLD}$total${NC} available ($agent_count agent + $op_count opencode)"
    echo -e "  ${CYAN}Routing:${NC}   \$skill-name explicit · trigger-word implicit"
    echo -e "  ${CYAN}Index:${NC}    $SKILL_INDEX"
    echo ""
}

# ── Launch ──
launch() {
    local target="${1:-.}"
    local extra_args=()

    if [ -d "$target" ]; then
        cd "$target"
        shift 2>/dev/null || true
        extra_args=("$@")
    elif [ -n "${1:-}" ]; then
        extra_args=("$@")
    fi

    export OPENCODE_CONFIG="$HOME/.config/opencode/opencode.json"
    exec "$OPENCODE_BIN" "${extra_args[@]}"
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    banner
    ensure_ollama
    ensure_model
    ensure_config
    build_skill_index
    bootstrap_project "${1:-$(pwd)}"
    show_status
    launch "$@"
}

main "$@"
