#!/usr/bin/env bash
# ─── eburoncode ───────────────────────────────────────────────────────
# Launch OpenCode TUI powered by the Eburon AI sandbox model.
# Requires Ollama and the media-pipe/eburon-sandbox-worker model.
#
# Usage:
#   eburoncode                 # Launch in current directory
#   eburoncode /path/to/project  # Launch in specific project
#   eburoncode "build me a todo app"  # Launch with initial prompt
#
# Prerequisites (auto-handled):
#   - Ollama running on localhost:11434
#   - media-pipe/eburon-sandbox-worker model pulled (1GB)
#   - OpenCode CLI installed
# ───────────────────────────────────────────────────────────────────────

set -euo pipefail

EBURON_MODEL="${EBURON_MODEL:-media-pipe/eburon-sandbox-worker}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"
OPENCODE_BIN="${OPENCODE_BIN:-opencode}"
CONFIG_DIR="${HOME}/.config/eburoncode"

# ── Colors ──
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  ╔═══════════════════════════════════════════╗"
    echo "  ║     🤖 eburoncode — Eburon AI + OpenCode ║"
    echo "  ║     model: $EBURON_MODEL"
    echo "  ╚═══════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ── Ensure Ollama is running ──
ensure_ollama() {
    if curl -s --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
        return 0
    fi

    echo -e "${YELLOW}Ollama not running — starting...${NC}"

    if command -v ollama >/dev/null 2>&1; then
        ollama serve >/dev/null 2>&1 &
        sleep 2
        if curl -s --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
            echo -e "${GREEN}✓ Ollama started${NC}"
            return 0
        fi
    fi

    echo -e "${RED}✗ Cannot reach Ollama at $OLLAMA_URL${NC}"
    echo "  Install: curl -fsSL https://ollama.com/install.sh | sh"
    echo "  Then:    ollama serve"
    exit 1
}

# ── Ensure model is pulled ──
ensure_model() {
    if ollama list 2>/dev/null | grep -q "$EBURON_MODEL"; then
        return 0
    fi

    echo -e "${YELLOW}Model not found locally — pulling $EBURON_MODEL...${NC}"
    echo -e "  (1GB download — one time only)"
    ollama pull "$EBURON_MODEL" || {
        echo -e "${RED}✗ Failed to pull model${NC}"
        echo "  Pull manually: ollama pull $EBURON_MODEL"
        exit 1
    }
    echo -e "${GREEN}✓ Model ready${NC}"
}

# ── Ensure OpenCode config ──
ensure_config() {
    mkdir -p "$CONFIG_DIR"
    local config_file="$HOME/.config/opencode/opencode.json"

    if [ ! -f "$config_file" ]; then
        mkdir -p "$(dirname "$config_file")"
        cat > "$config_file" <<EOF
{
  "provider": "ollama",
  "model": "$EBURON_MODEL",
  "ollama": {
    "url": "$OLLAMA_URL"
  }
}
EOF
    fi
}

# ── Launch ──
launch() {
    # Parse args: first arg can be a directory path or a prompt
    local target="${1:-.}"
    local extra_args=()

    if [ -d "$target" ]; then
        # It's a directory — cd into it
        cd "$target"
        shift 2>/dev/null || true
        extra_args=("$@")
    elif [ -n "${1:-}" ]; then
        # It's a prompt or flags — pass through
        extra_args=("$@")
    fi

    echo ""
    echo -e "${CYAN}Provider:${NC} ollama"
    echo -e "${CYAN}Model:${NC}    $EBURON_MODEL"
    echo -e "${CYAN}Working:${NC}   $(pwd)"
    echo ""

    # Ensure OpenCode uses the eburon config
    export OPENCODE_CONFIG="$HOME/.config/opencode/opencode.json"

    exec "$OPENCODE_BIN" "${extra_args[@]}"
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    banner
    ensure_ollama
    ensure_model
    ensure_config
    launch "$@"
}

main "$@"
