#!/usr/bin/env bash
# ─── skill-index — Build Skill Routing Index ─────────────────────────
# Scans all installed skills and generates an index file that OpenCode
# can use for fast implicit skill matching via progressive disclosure.
#
# Output: ~/.config/opencode/skills-index.md
# Usage:  skill-index           # Generate index
#         skill-index --watch   # Watch and rebuild on changes
# ───────────────────────────────────────────────────────────────────────

set -euo pipefail

SKILL_DIRS=("${HOME}/.agents/skills" "${HOME}/.opencode/skills")
INDEX_FILE="${HOME}/.config/opencode/skills-index.md"

generate_index() {
    local total=0
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')

    {
        echo "# Skill Routing Index"
        echo "> Generated: $timestamp | Total: $(find "${SKILL_DIRS[@]}" -name "SKILL.md" 2>/dev/null | wc -l | tr -d ' ') skills"
        echo ""
        echo "## Explicit Invocation"
        echo 'Use `$skill-name` or "use skill-name" to load a skill directly.'
        echo ""
        echo "## Implicit Matching — Trigger Words → Skills"
        echo ""
        echo "| Trigger Words | Skill | Description |"
        echo "|--------------|-------|-------------|"
    } > "$INDEX_FILE"

    for dir in "${SKILL_DIRS[@]}"; do
        [ -d "$dir" ] || continue
        for skill_dir in "$dir"/*/; do
            [ -d "$skill_dir" ] || continue
            local f="$skill_dir/SKILL.md"
            [ -f "$f" ] || continue

            local name=$(grep "^name:" "$f" | head -1 | sed 's/name: *//')
            local desc=$(grep "^description:" "$f" | head -1 | sed 's/description: *//')
            local hint=$(grep "^argument-hint:" "$f" | head -1 | sed 's/argument-hint: *//')
            [ -z "$name" ] && continue

            # Extract trigger words from description and hint
            local triggers="${hint:-$desc}"
            # Truncate for table
            local short_desc="${desc:0:80}"
            [ "${#desc}" -gt 80 ] && short_desc="${short_desc}..."

            echo "| \`${triggers:0:60}\` | \`${name}\` | ${short_desc} |" >> "$INDEX_FILE"
            total=$((total + 1))
        done
    done

    {
        echo ""
        echo "## How Matching Works"
        echo ""
        echo "1. Scan this index for trigger words matching the user's task"
        echo "2. Match trigger words → skill name → load SKILL.md from path"
        echo "3. Follow the skill workflow (inspect → apply → verify → summarize)"
        echo ""
        echo "## Quick Load Commands"
        echo ""
        echo '```bash'
        echo '# Load agent skills'
        echo 'ls ~/.agents/skills/*/SKILL.md'
        echo ''
        echo '# Load opencode skills'
        echo 'ls ~/.opencode/skills/*/SKILL.md'
        echo ''
        echo '# Read skill description only (progressive disclosure)'
        echo 'for f in ~/.agents/skills/*/SKILL.md ~/.opencode/skills/*/SKILL.md; do'
        echo '  [ -f "$f" ] && head -8 "$f" | grep -E "^(name:|description:)" | paste - -'
        echo 'done'
        echo '```'
        echo ""
        echo "---"
        echo "*Auto-generated by eburoncode skill-index*"
    } >> "$INDEX_FILE"

    echo "✓ Skill index generated: $total skills → $INDEX_FILE"
}

# ── Main ──
mkdir -p "$(dirname "$INDEX_FILE")"

case "${1:-}" in
    --watch)
        echo "Watching skills directories for changes..."
        while true; do
            generate_index
            sleep 300  # rebuild every 5 minutes
        done
        ;;
    *)
        generate_index
        ;;
esac
